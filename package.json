{
  "name": "trumpet-practice-hero",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:start": "cross-env ELECTRON_DEV=true electron .",
    "electron:build": "vite build && electron .",
    "electron:pack": "vite build && electron-packager . TrumpetPracticeHero --platform=win32 --arch=x64 --out=dist-desktop --overwrite --asar",
    "check-ai": "node scripts/check-ai.js"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-packager": "^17.1.2",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  }
}
